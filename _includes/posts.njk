<section>
	<div class="grid other">
		<h2>Projects</h2>
		<div class="row blog-card">
		{% for post in posts %}
			<article class="cards">
						<div class="card-txt">
							<div class="main-txt">
								<h3>{{ post.data.title }}</h3>
								<p class="d">{{ post.data.tldr }}</p>
								<div class="main-txt-links">
									<a href="/projects/{{ post.data.name }}" title="{{ post.data.title }}">View case study &#x276F;</a>
									{% if post.data.website %}
										<a href="https://{{ post.data.website }}" title="{{ post.data.website }}">Visit site</a>
									{% endif %}			
								</div>
							</div>
						</div>
						<div class="card-img">
							<img src="{{ post.data.image }}">
						</div>
				</article>
		{% endfor %}
		</div>
	</div>
</section>
